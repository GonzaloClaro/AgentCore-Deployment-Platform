# .env.example — plantilla para desarrollo LOCAL.
# Copia este archivo a .env y rellena los valores.
# .env está en .gitignore para evitar commitear secretos.
#
# Para producción, los mismos valores se configuran como CI/CD variables en GitLab
# (ver CI_VARIABLES.md). Este archivo es SOLO para correr scripts/templates localmente.

# =============================================================================
# AWS — credenciales y cuentas
# =============================================================================
AWS_REGION=us-east-1
AWS_PROFILE=agentcore-dev                      # perfil ~/.aws/credentials para tests locales

AWS_ACCOUNT_ID_DEV=                            # 12 dígitos
AWS_ACCOUNT_ID_QA=
AWS_ACCOUNT_ID_PRD=

AWS_ROLE_ARN_DEV=arn:aws:iam::$AWS_ACCOUNT_ID_DEV:role/agentcore-dev-deployer
AWS_ROLE_ARN_QA=arn:aws:iam::$AWS_ACCOUNT_ID_QA:role/agentcore-qa-deployer
AWS_ROLE_ARN_PRD=arn:aws:iam::$AWS_ACCOUNT_ID_PRD:role/agentcore-prd-deployer

# =============================================================================
# GitLab — runners, tokens, paths
# =============================================================================
CI_SERVER_HOST=gitlab.example.com
CI_SERVER_FQDN=gitlab.example.com

ORG_RUNNER_IMAGE=internal-registry/runners/python-aws:1.0
GITLAB_TOKEN_READ_API=                         # group token con scope read_api

# Paths de los proyectos (sirven para multi-project triggers)
COMPONENT_REPO_PATH=Componentes/agentcore
COMPOSE_REPO_PATH=Componentes/Compose/agentcore
INFRA_REPO_PATH=iac/AgentCore/infra-agentcore
DEV_DEPLOYABLE_PATH=iac/AgentCore/agentcore-dev
QA_DEPLOYABLE_PATH=iac/AgentCore/agentcore-qa
PRD_DEPLOYABLE_PATH=iac/AgentCore/agentcore-prd

# =============================================================================
# OAuth — para componentes upload_secret y composición mcp-server
# =============================================================================
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_DISCOVERY_URL_3LO=                       # ej: https://idp.example.com/.well-known/openid-configuration
OAUTH_DISCOVERY_URL_2LO=
OAUTH_AUDIENCE_3LO=agentcore-3lo
OAUTH_AUDIENCE_2LO=agentcore-2lo

# =============================================================================
# Catálogo — LeanIX
# =============================================================================
LEANIX_ENDPOINT=https://app.leanix.net/services/api/v1
LEANIX_API_TOKEN=

# =============================================================================
# Workload de prueba (smoke)
# =============================================================================
WORKLOAD_PATH=agents/sandbox/hello-world
CAPABILITY=sandbox
WORKLOAD_NAME=hello-world
ENVIRONMENT=dev

# =============================================================================
# Buckets S3 (auto-derivados de la convención, override solo si es necesario)
# =============================================================================
# S3_ARTIFACTS_BUCKET=artifacts-dev-agentcore-agents

# =============================================================================
# Foundation — vars del módulo default-gateways (idP corporativo)
# =============================================================================
# Estos van directo a foundation/default-gateways/ via -var (no son CI vars).
# Aquí están solo si quieres aplicar foundation desde tu máquina local.
FOUNDATION_OAUTH_3LO_DISCOVERY_URL=$OAUTH_DISCOVERY_URL_3LO
FOUNDATION_OAUTH_2LO_DISCOVERY_URL=$OAUTH_DISCOVERY_URL_2LO
