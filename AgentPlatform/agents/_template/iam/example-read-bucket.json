{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadKBBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::my-org-kb-public",
        "arn:aws:s3:::my-org-kb-public/*"
      ]
    },
    {
      "Sid": "AllowInvokeToolLambda",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:us-east-1:111122223333:function:tool-calculator-*"
    }
  ]
}
