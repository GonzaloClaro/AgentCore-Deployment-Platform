# Terraform working artifacts (descargados en init, NO commitear)
.terraform/
.terraform.tfstate.lock.info

# Lock files: SI commitear (determinismo provider version entre local y CI)
# .terraform.lock.hcl   ← intencionalmente NO ignorado

# State files: este repo NO maneja state propio (los deployables agentcore-{dev,qa,prd} sí).
# Cualquier .tfstate aquí es accidental.
*.tfstate
*.tfstate.*
*.tfstate.backup

# tfvars: los manifests del CI generan terraform.auto.tfvars.json en build time.
terraform.auto.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Crash logs y override files
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Backups del editor / sistema
*.bak
*.swp
.DS_Store
