{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentcore/manifest-fase0.schema.json",
  "title": "AgentCore Workload Manifest (fase 0 — zip mode)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["v1"]
    },
    "kind": {
      "type": "string",
      "enum": ["Agent"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "capability", "owner"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,40}$",
          "description": "Nombre del agente (kebab-case, único dentro del capability)."
        },
        "capability": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,40}$",
          "description": "Capability/equipo al que pertenece el workload."
        },
        "owner": {
          "type": "string",
          "description": "Email del owner técnico."
        },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["composition", "runtime"],
      "properties": {
        "composition": {
          "type": "string",
          "enum": ["agent-base-zip", "agent-with-kb-zip"],
          "description": "Composición Terraform de fase 0. Solo zip mode (no container)."
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entrypoint"],
          "properties": {
            "entrypoint": {
              "type": "string",
              "description": "Archivo Python en src/ que arranca el HTTP server (ej: main.py)."
            },
            "runtime_version": {
              "type": "string",
              "enum": ["PYTHON_3_13"],
              "default": "PYTHON_3_13",
              "description": "Versión Python soportada por AgentCore. En fase 0 solo Python 3.13."
            },
            "env": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "description": "Variables de entorno inyectadas al runtime."
            }
          }
        },
        "models": {
          "type": "array",
          "description": "Modelos LLM que el agente invoca via Bedrock Converse API.",
          "items": {
            "type": "object",
            "required": ["alias", "provider"],
            "additionalProperties": false,
            "properties": {
              "alias": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_]{0,63}$",
                "description": "Nombre de la env var (UPPER_SNAKE). Ej: PRIMARY_MODEL."
              },
              "provider": {
                "type": "string",
                "enum": ["bedrock", "azure"]
              },
              "bedrock": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "model_id": {
                    "type": "string",
                    "description": "Model ID o cross-region inference profile (prefijo 'us.' / 'eu.')."
                  },
                  "region": { "type": "string" },
                  "inference_profile_arn": { "type": "string" }
                }
              },
              "azure": {
                "type": "object",
                "additionalProperties": false,
                "required": ["endpoint", "deployment", "api_version", "api_key_secret_var"],
                "properties": {
                  "endpoint": { "type": "string", "format": "uri" },
                  "deployment": { "type": "string" },
                  "model_id": { "type": "string" },
                  "api_version": { "type": "string" },
                  "api_key_secret_var": { "type": "string" }
                }
              }
            }
          }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "description": "Solo aplicable si composition=agent-with-kb-zip.",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["summarization", "semantic", "user-preference", "none"],
              "default": "summarization"
            }
          }
        },
        "knowledge_base": {
          "type": "object",
          "additionalProperties": false,
          "description": "Solo aplicable si composition=agent-with-kb-zip.",
          "properties": {
            "embedding": {
              "type": "string",
              "default": "amazon.titan-embed-text-v2:0"
            },
            "sources_file": {
              "type": "string",
              "description": "Path al YAML con sources S3 (relativo al manifest)."
            }
          }
        },
        "prompts": {
          "type": "array",
          "description": "Prompts versionados via Bedrock Prompt Management.",
          "items": {
            "type": "object",
            "required": ["file"],
            "additionalProperties": false,
            "properties": {
              "file": { "type": "string" },
              "alias": { "type": "string" }
            }
          }
        },
        "observability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": { "type": "boolean" },
          "properties": {
            "enable_observability": { "type": "boolean", "default": true }
          }
        }
      }
    }
  }
}
